---
/**
 * Base Layout - All pages extend this
 */
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The open-source playground for junior developers' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const normalizedBase = (baseUrl || '').replace(/\/+$/, '');
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Platform</title>
  <link rel="icon" type="image/svg+xml" href={`${normalizedBase}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
</head>
<body class="bg-dark-bg text-dark-text min-h-screen">
  <!-- Navigation -->
  <nav class="border-b border-dark-border sticky top-0 bg-dark-bg/80 backdrop-blur-sm z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href={baseUrl} class="flex items-center gap-2 text-xl font-bold">
          <span class="text-2xl">🎮</span>
          <span>Platform</span>
        </a>
        <div class="flex items-center gap-6">
          <a href={`${normalizedBase}/games`} class="text-dark-muted hover:text-white transition">Games</a>
          <a href={`${normalizedBase}/leaderboard`} class="text-dark-muted hover:text-white transition">Leaderboard</a>
          <a href={`${normalizedBase}/contributors`} class="text-dark-muted hover:text-white transition">Contributors</a>
          <a href="https://github.com/AbdullahOztoprak/Platform" target="_blank" class="text-dark-muted hover:text-white transition">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-dark-border mt-20 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-dark-muted text-sm">
          Built with ❤️ for the open-source community
        </p>
        <div class="flex items-center gap-4 text-sm text-dark-muted">
          <a href="https://github.com/AbdullahOztoprak/Platform/blob/main/CONTRIBUTING.md" class="hover:text-white">Contribute</a>
          <a href="https://github.com/AbdullahOztoprak/Platform/blob/main/CODE_OF_CONDUCT.md" class="hover:text-white">Code of Conduct</a>
          <a href="https://github.com/AbdullahOztoprak/Platform" class="hover:text-white">GitHub</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
