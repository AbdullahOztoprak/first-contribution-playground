---
/**
 * Leaderboard Table Component
 */
interface Entry {
  rank: number;
  username: string;
  avatar_url: string;
  game_name: string;
  votes: number;
  weighted_score: number;
  difficulty?: string;
}

interface Props {
  entries: Entry[];
  title?: string;
}

const { entries, title = 'Leaderboard' } = Astro.props;

const medals = ['🥇', '🥈', '🥉'];
const difficultyBadges: Record<string, string> = {
  beginner: '🟢',
  intermediate: '🟡',
  advanced: '🔴',
};
---

<div class="bg-dark-card border border-dark-border rounded-xl overflow-hidden">
  <div class="px-6 py-4 border-b border-dark-border">
    <h3 class="text-lg font-semibold">{title}</h3>
  </div>
  
  <div class="divide-y divide-dark-border">
    {entries.length === 0 ? (
      <div class="px-6 py-12 text-center text-dark-muted">
        <p class="text-4xl mb-2">🎮</p>
        <p>No entries yet. Be the first to submit!</p>
      </div>
    ) : (
      entries.map((entry, i) => (
        <div class="px-6 py-4 flex items-center gap-4 hover:bg-dark-bg/50 transition">
          <span class="w-8 text-center text-xl">
            {i < 3 ? medals[i] : <span class="text-dark-muted">{entry.rank}</span>}
          </span>
          
          <img 
            src={entry.avatar_url}
            alt={entry.username}
            class="w-10 h-10 rounded-full"
          />
          
          <div class="flex-1 min-w-0">
            <p class="font-medium truncate">{entry.game_name}</p>
            <p class="text-sm text-dark-muted">@{entry.username}</p>
          </div>
          
          {entry.difficulty && (
            <span class="text-lg" title={entry.difficulty}>
              {difficultyBadges[entry.difficulty] || '⚪'}
            </span>
          )}
          
          <div class="text-right">
            <p class="font-semibold">👍 {entry.votes}</p>
            <p class="text-xs text-dark-muted">{entry.weighted_score?.toFixed(1) || entry.votes} pts</p>
          </div>
        </div>
      ))
    )}
  </div>
</div>
